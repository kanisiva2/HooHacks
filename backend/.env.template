# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Supabase ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Pooler URL (port 6543) — used by the FastAPI app
DATABASE_URL=postgresql+asyncpg://postgres.your-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct URL (port 5432) — used by Alembic ONLY
DATABASE_DIRECT_URL=postgresql+asyncpg://postgres.your-ref:your-password@db.your-ref.supabase.co:5432/postgres

# ── AWS S3 ──
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=sprynt-artifacts

# ── LLM ──
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=                          # Optional — only if using OpenAI instead of Anthropic

# ── Skribby (Meeting Bot API) ──
SKRIBBY_API_KEY=your_skribby_api_key

# ── ElevenLabs (stretch goal — not required for MVP) ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── GitHub OAuth ──
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/integrations/github/callback

# ── Jira OAuth ──
JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret
JIRA_REDIRECT_URI=http://localhost:8000/api/integrations/jira/callback
